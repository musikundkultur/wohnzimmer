{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": ["minijinja crates"],
      "groupName": "minijinja crates",
      "matchPackageNames": ["/minijinja/"],
      "matchDatasources": ["cargo"],
      "group": {
        "commitMessageTopic": "{{{groupName}}}"
      },
      "separateMinorPatch": true
    },
    {
      "description": ["reqwest crates"],
      "groupName": "reqwest crates",
      "matchPackageNames": ["/reqwest/"],
      "matchDatasources": ["cargo"],
      "group": {
        "commitMessageTopic": "{{{groupName}}}"
      },
      "separateMinorPatch": true
    }
  ]
}
